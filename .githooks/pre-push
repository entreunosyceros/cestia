#!/bin/sh
# Bloquea git push si algún commit incluye secretos o datos locales.
# Activa con: git config core.hooksPath .githooks

set -e

es_sensible() {
    case "$1" in
        .env.example) return 1 ;;
        .env) return 0 ;;
        .env.*) return 0 ;;
        datos/*|data/*|.cache/*) return 0 ;;
        *.db|*.sqlite|*.sqlite3) return 0 ;;
        *) return 1 ;;
    esac
}

while read -r local_ref local_sha remote_ref remote_sha; do
    [ "$local_sha" = "0000000000000000000000000000000000000000" ] && continue

    if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
        commits=$(git rev-list "$local_sha" 2>/dev/null || true)
    else
        commits=$(git rev-list "$remote_sha".."$local_sha" 2>/dev/null || true)
    fi

    for commit in $commits; do
        for archivo in $(git diff-tree --no-commit-id --name-only -r "$commit" 2>/dev/null); do
            if es_sensible "$archivo"; then
                echo "pre-push: bloqueado — «$archivo» contiene datos locales o secretos." >&2
                echo "pre-push: no subas .env, datos/, data/ ni *.db a GitHub." >&2
                exit 1
            fi
        done
    done
done

exit 0
